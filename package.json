{
  "name": "ai-pet-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Pet monorepo",
  "scripts": {
    "prepare": "husky",
    "fix:all": "pnpm fix:prettier && pnpm fix:eslint",
    "fix:prettier": "prettier --config ./.prettierrc --write .",
    "fix:eslint": "eslint --config ./eslint.config.js --fix --quiet --no-warn-ignored .",
    "deploy": "pnpm -F pet-skins deploy",
    "pet:open": "pnpm -F ai-pet open",
    "pet:sync": "pnpm -F ai-pet sync-version",
    "pet:dev": "pnpm -F ai-pet dev",
    "build:mac": "pnpm -F ai-pet build:mac",
    "build:win": "pnpm -F ai-pet build:win",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^9",
    "eslint-config-jshow": "^1.0.16",
    "eslint-config-prettier": "latest",
    "eslint-plugin-jshow": "^1.0.15",
    "eslint-plugin-prettier": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": ">=3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
