{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Pet",
  "version": "1.0.0",
  "identifier": "com.jshow.ai-pet",
  "build": {
    "beforeDevCommand": "node scripts/sync-pets.mjs && vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/sync-pets.mjs && tsc && vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Pet",
        "width": 192,
        "height": 208,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.ai-pet/pets/**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aipet"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "../public/default/": "default/"
    }
  }
}
