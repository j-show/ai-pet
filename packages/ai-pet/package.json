{
  "name": "ai-pet",
  "version": "1.0.0",
  "description": "Tauri desktop AI Pet",
  "author": {
    "name": "jShow",
    "email": "dev@jshow.org"
  },
  "homepage": "https://github.com/j-show/ai-pet",
  "repository": {
    "type": "git",
    "url": "https://github.com/j-show/ai-pet.git"
  },
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "icon": "node scripts/prepare-icon-source.mjs && tauri icon src-tauri/icons/icon-source.png -o src-tauri/icons",
    "export": "node scripts/export-dist.mjs",
    "open": "node scripts/aipet-open.mjs",
    "sync-pets": "node scripts/sync-pets.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "preview": "vite preview",
    "dev": "tauri dev",
    "build:mac": "pnpm build:app",
    "build:win": "pnpm build:app && pnpm build:portable",
    "build:app": "tauri build",
    "build:portable": "tauri build --no-bundle --config src-tauri/tauri.portable.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "pngjs": "^7.0.0",
    "vite": "^6.0.3"
  }
}
