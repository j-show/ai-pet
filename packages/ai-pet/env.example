# Copy to ~/.ai-pet/.env (created automatically on first run if missing)
#
# PET                    Default pet id
PET=sugarwing
# AI_PET_ANIMATION_TICK  Frame interval in milliseconds for all animations
AI_PET_ANIMATION_TICK=250
# AI_PET_THEME            Theme: auto | light | dark (auto follows system)
AI_PET_THEME=auto

# User pet packages: ~/.ai-pet/pets/<petId>/{pet.json,spritesheet.webp,...}
# Fallback bundled pet: ai-pet/public/default/
